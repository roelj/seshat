Name:          seshat
Version:       @VERSION@
Release:       1%{?dist}
Summary:       Data and software repository system
License:       AGPL-3.0-or-later
URL:           @GIT_URL@
Source0:       %{name}-%{version}.tar.gz
BuildArch:     noarch

# RHEL 8 defaults to Python 3.6, which is EOL. Use python3.9 instead.
%if 0%{?rhel} == 8
BuildRequires: python39-rpm-macros
%global python3_pkgversion 39
%else
# The 'build' module is only packaged outside RHEL 8.
BuildRequires: python%{python3_pkgversion}-build
%endif

BuildRequires: make
BuildRequires: systemd-rpm-macros
BuildRequires: python%{python3_pkgversion}-devel
BuildRequires: python%{python3_pkgversion}-pip
BuildRequires: python%{python3_pkgversion}-setuptools
BuildRequires: python%{python3_pkgversion}-wheel

Requires:      git
Requires:      python%{python3_pkgversion}-defusedxml
Requires:      python%{python3_pkgversion}-jinja2
Requires:      python%{python3_pkgversion}-pillow
Requires:      python%{python3_pkgversion}-pygit2
Requires:      python%{python3_pkgversion}-rdflib
Requires:      python%{python3_pkgversion}-requests
Requires:      python%{python3_pkgversion}-werkzeug

%description
This package provides a data and software repository system.

%prep
%autosetup -p1 -n %{name}-%{version}

%build
%{configure} PYTHON=%{__python3}
make

%install
%if 0%{?rhel} == 8 || 0%{?rhel} == 9
cat > setup.cfg << EOF
[metadata]
name = %{name}
version = @VERSION_FOR_PYTHON@
url = %{url}

[install]
prefix = %{buildroot}/usr

[options]
package_dir =
    = src
packages =
    seshat
    seshat.web
    seshat.utils

[options.package_data]
seshat =
    web/resources/*
    web/resources/html_templates/*
    web/resources/html_templates/admin/*
    web/resources/html_templates/admin/reports/*
    web/resources/html_templates/depositor/*
    web/resources/html_templates/email/*
    web/resources/html_templates/review/*
    web/resources/metadata_templates/*
    web/resources/sparql_templates/*
    web/resources/static/css/*
    web/resources/static/fonts/*
    web/resources/static/images/*
    web/resources/static/images/datatables/*
    web/resources/static/js/*
    web/resources/static/js/ace/*

[options.entry_points]
console_scripts =
    seshat = seshat.ui:main
EOF
%endif
make install DESTDIR=%{buildroot}
install -Dpm 0644 etc/%{name}.service %{buildroot}%{_unitdir}/%{name}.service
install -Dpm 0644 etc/%{name}.xml %{buildroot}%{_sysconfdir}/%{name}.xml
%py3_shebang_fix %{buildroot}%{_bindir}/

%files
%license LICENSE
%doc README.md
%{python3_sitelib}/%{name}/
%{python3_sitelib}/%{name}-@VERSION_FOR_PYTHON@*
%{_unitdir}/%{name}.service
%config(noreplace) %{_sysconfdir}/%{name}.xml
%{_bindir}/%{name}
%dir %{_datadir}/%{name}
%{_datadir}/%{name}/%{name}.pdf
%{_datadir}/%{name}/index.html
%if @WITH_HELM@
%{_datadir}/%{name}/index.yaml
%{_datadir}/%{name}/seshat-1.0.0.tgz
%endif
%{_mandir}/man1/seshat.1*

%post
%systemd_post %{name}.service

%preun
%systemd_preun %{name}.service

%postun
%systemd_postun_with_restart %{name}.service

%changelog
* Sat May 30 2026 Malaika Newman <symmetricbutterfly@proton.me> - 26.5-1
- Release version 26.5.
* Thu Apr 30 2026 Malaika Newman <symmetricbutterfly@proton.me> - 26.4-1
- Release version 26.4.
* Mon Apr 20 2026 Roel Janssen <rrejanssen@gmail.com> - 26.4-0.1.rc1
- Ensure RPM builds work without internet connection by providing an
  alternative to the 'build' module.
* Mon Mar 2 2026 Roel Janssen <rrejanssen@gmail.com> 25.6-1
- Clean-up LaTeX legacy
* Fri Jan 31 2025 Roel Janssen <r.r.e.janssen@tudelft.nl> 25.1-1
- Initial RPM creation.
- See https://seshat.software/#news for the full release notes.
